PORT=8787

# Select provider: aviationstack | flightaware
FLIGHT_DATA_PROVIDER=aviationstack

# Aviationstack settings
AVIATIONSTACK_KEY=your_aviationstack_key_here
AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1

# FlightAware AeroAPI settings
FLIGHTAWARE_API_KEY=your_flightaware_aeroapi_key_here
FLIGHTAWARE_BASE_URL=https://aeroapi.flightaware.com/aeroapi

# FlightAware Firehose settings (for continuous live tracked-flight updates)
# Use your FlightAware account username plus your Firehose API key.
FIREHOSE_HOST=firehose.flightaware.com
FIREHOSE_PORT=1501
FIREHOSE_USERNAME=
FIREHOSE_API_KEY=
# Optional legacy alias if you already use it:
# FIREHOSE_PASSWORD=
FIREHOSE_VERSION=36.0
FIREHOSE_USER_AGENT=runwy-firehose
FIREHOSE_EVENTS=flifo departure arrival cancellation position
FIREHOSE_KEEPALIVE_SECONDS=60
FIREHOSE_MIN_SECONDS_BETWEEN_AIRBORNE=15
FIREHOSE_TRACKED_SET_REFRESH_MS=60000
FIREHOSE_RECONNECT_DELAY_MS=5000
FIREHOSE_TRACK_LOOKAHEAD_HOURS=2
FIREHOSE_POST_ARRIVAL_BUFFER_MINUTES=45
FIREHOSE_BACKFILL_MAX_HOURS=8
FIREHOSE_BACKFILL_PREDEPARTURE_MINUTES=15
FIREHOSE_BACKFILL_MIN_TRACK_POINTS=8

CACHE_TTL_MS=90000
RATE_LIMIT_PER_MINUTE=60

# Optional webhook auth for provider -> Runwy backend callbacks.
WEBHOOK_SHARED_SECRET=

# Backend auth verification for /v1 routes.
# Prefer SUPABASE_JWT_SECRET (local JWT verification). If unavailable,
# set both SUPABASE_URL and SUPABASE_ANON_KEY to verify via Supabase Auth API.
SUPABASE_JWT_SECRET=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Only use for explicit local debug; unsafe for production.
ALLOW_INSECURE_NO_AUTH=false
DEBUG_USER_ID=

# Optional request/cache limits.
AUTH_CACHE_TTL_MS=300000
MAX_AUTH_CACHE_ENTRIES=5000
MAX_PROVIDER_CACHE_ENTRIES=2000

# Optional in-memory fallback limits.
MAX_MEMORY_TRACKED_FLIGHTS=10000
MAX_MEMORY_PUSH_DEVICES=25000

# Poller tuning.
POLLER_INTERVAL_MS=30000
POLLER_BATCH_SIZE=25
STALE_FETCH_REFRESH_THRESHOLD_MS=90000

# API processes should keep this false.
# The dedicated poller worker entrypoint ignores this and starts polling directly.
ENABLE_TRACKING_POLLER=false
ENABLE_FIREHOSE_WORKER=false

# Optional persistent storage. If unset, in-memory maps are used.
DATABASE_URL=
DATABASE_SSL=false

# APNs for delayed/cancelled push notifications.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=

# Supply one of the two private-key formats:
# 1) Raw key with escaped newlines, or
# 2) Base64-encoded key content (recommended for env stores)
APNS_PRIVATE_KEY=
APNS_PRIVATE_KEY_BASE64=

# true for development/TestFlight sandbox pushes, false for production APNs.
APNS_USE_SANDBOX=true
