{
  "name": "aviationstack-proxy",
  "version": "1.0.0",
  "private": true,
  "description": "Backend proxy for Aviationstack with normalization, rate limiting, and caching.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "build:airports": "node scripts/build-airports-dataset.js",
    "doctor": "node scripts/doctor.js",
    "test": "node --test test/*.test.js",
    "start": "node src/start.js",
    "start:api": "ENABLE_TRACKING_POLLER=false node src/server.js",
    "start:poller": "node src/flight-poller.js",
    "start:firehose": "node src/flight-firehose.js",
    "start:all": "ENABLE_TRACKING_POLLER=true node src/server.js",
    "dev": "npm run dev:api",
    "dev:api": "ENABLE_TRACKING_POLLER=false node --watch src/server.js",
    "dev:poller": "node --watch src/flight-poller.js",
    "dev:firehose": "node --watch src/flight-firehose.js"
  },
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.1.0",
    "pg": "^8.11.5",
    "zod": "^4.3.6"
  }
}
